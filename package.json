{
	"name": "expiry-manager",
	"version": "1.0.0",
	"description": "Track anything that expires, renews, or needs periodic attention.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "bun esbuild.config.mjs",
		"build": "bunx tsc --noEmit --skipLibCheck && bun esbuild.config.mjs production",
		"version": "bun version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": ["obsidian", "plugin", "expiry", "subscription", "manager"],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	}
}
