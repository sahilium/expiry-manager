{
	"name": "expiry-manager",
	"version": "1.0.0",
	"description": "Track anything that expires, renews, or needs periodic attention. Manage subscriptions, documents, licenses, and more from within Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"expiry",
		"expiry-manager",
		"subscription",
		"lifecycle",
		"reminders"
	],
	"license": "MIT",
	"author": "sahilium",
	"repository": {
		"type": "git",
		"url": "https://github.com/sahilium/expiry-manager"
	},
	"bugs": {
		"url": "https://github.com/sahilium/expiry-manager/issues"
	},
	"homepage": "https://github.com/sahilium/expiry-manager",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	}
}
